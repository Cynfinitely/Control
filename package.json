{
  "name": "control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-prisma-provider.mjs && prisma generate && next dev",
    "build": "node scripts/sync-prisma-provider.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/sync-prisma-provider.mjs && prisma generate",
    "db:push": "node scripts/sync-prisma-provider.mjs && prisma db push",
    "db:migrate": "node scripts/sync-prisma-provider.mjs && prisma migrate dev",
    "db:migrate:deploy": "node scripts/sync-prisma-provider.mjs && node scripts/setup-db.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "node scripts/sync-prisma-provider.mjs && prisma studio",
    "setup": "node scripts/sync-prisma-provider.mjs && prisma generate && node scripts/setup-db.mjs && tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "^14.2.33",
    "next-auth": "^4.24.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
