# Database — pick ONE:
#
# Local dev (SQLite, no extra setup):
DATABASE_URL="file:./dev.db"
#
# Local or production PostgreSQL (Docker: docker compose up -d):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/control?schema=public"
#
# Production (Neon) — use BOTH URLs:
# Pooled connection for app runtime (host includes "-pooler"):
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct connection for migrations only (no "-pooler" in host):
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
